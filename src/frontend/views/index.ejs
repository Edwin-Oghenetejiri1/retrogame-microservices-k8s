<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>RetroGame Shop</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: Arial, sans-serif; background: #1a1a2e; color: #eee; }
        header { background: #16213e; padding: 20px; text-align: center; }
        header h1 { color: #e94560; font-size: 2.5rem; }
        nav a { color: #e94560; text-decoration: none; margin: 0 10px; }
        .container { max-width: 1000px; margin: 40px auto; padding: 0 20px; }
        .tabs { display: flex; gap: 10px; margin-bottom: 30px; }
        .tab-btn { background: #16213e; color: #a8a8b3; border: 1px solid #0f3460; padding: 8px 20px; border-radius: 20px; cursor: pointer; font-size: 0.9rem; }
        .tab-btn:hover { border-color: #4ecca3; color: #4ecca3; }
        .tab-btn.active { background: #0f3460; color: #4ecca3; border-color: #4ecca3; }
        .section { margin-bottom: 40px; }
        .section-title { font-size: 1rem; font-weight: 600; color: #a8a8b3; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 16px; padding-bottom: 8px; border-bottom: 1px solid #0f3460; }
        .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; }
        .card { background: #16213e; border-radius: 10px; padding: 20px; border: 1px solid #0f3460; display: flex; flex-direction: column; gap: 10px; }
        .card h3 { color: #e94560; font-size: 1.2rem; }
        .card p { color: #a8a8b3; font-size: 0.9rem; flex-grow: 1; }
        .price { color: #4ecca3; font-size: 1.3rem; font-weight: bold; }
        .btn { background: #e94560; color: white; border: none; padding: 10px 20px; border-radius: 5px; cursor: pointer; font-size: 1rem; width: 100%; }
        .btn:hover { background: #c73652; }
        .badge { background: #0f3460; color: #4ecca3; font-size: 0.75rem; padding: 3px 8px; border-radius: 20px; display: inline-block; }
        .empty { text-align: center; padding: 50px; color: #a8a8b3; }
        .hidden { display: none; }
    </style>
</head>
<body>
    <header>
        <h1>🕹️ RetroGame Shop</h1>
        <nav>
            <a href="/">Home</a>
            <a href="/cart/1">🛒 Cart</a>
        </nav>
    </header>

    <div class="container">
        <% if (products.length === 0) { %>
            <div class="empty">
                <h3>No products available</h3>
                <p>Check back later!</p>
            </div>
        <% } else { %>
            <div class="tabs">
                <button class="tab-btn active" onclick="filterTab(this, 'all')">All</button>
                <button class="tab-btn" onclick="filterTab(this, 'console')">Consoles</button>
                <button class="tab-btn" onclick="filterTab(this, 'game')">Games</button>
            </div>

            <div class="section" id="section-console">
                <div class="section-title">🎮 Consoles</div>
                <div class="grid">
                    <% products.filter(p => p.category === 'Console').forEach(function(product) { %>
                        <div class="card">
                            <span class="badge">🎮 Console</span>
                            <h3><%= product.name %></h3>
                            <p><%= product.description || 'A classic retro console.' %></p>
                            <div class="price">$<%= parseFloat(product.price).toFixed(2) %></div>
                            <form action="/cart/1/add" method="POST">
                                <input type="hidden" name="id" value="<%= product.id %>">
                                <input type="hidden" name="name" value="<%= product.name %>">
                                <input type="hidden" name="price" value="<%= product.price %>">
                                <button type="submit" class="btn">Add to Cart 🛒</button>
                            </form>
                        </div>
                    <% }) %>
                </div>
            </div>

            <div class="section" id="section-game">
                <div class="section-title">🕹️ Games</div>
                <div class="grid">
                    <% products.filter(p => p.category === 'Game').forEach(function(product) { %>
                        <div class="card">
                            <span class="badge">🕹️ Game</span>
                            <h3><%= product.name %></h3>
                            <p><%= product.description || 'A classic retro game.' %></p>
                            <div class="price">$<%= parseFloat(product.price).toFixed(2) %></div>
                            <form action="/cart/1/add" method="POST">
                                <input type="hidden" name="id" value="<%= product.id %>">
                                <input type="hidden" name="name" value="<%= product.name %>">
                                <input type="hidden" name="price" value="<%= product.price %>">
                                <button type="submit" class="btn">Add to Cart 🛒</button>
                            </form>
                        </div>
                    <% }) %>
                </div>
            </div>
        <% } %>
    </div>

    <script>
        function filterTab(el, filter) {
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            el.classList.add('active');
            document.getElementById('section-console').classList.toggle('hidden', filter === 'game');
            document.getElementById('section-game').classList.toggle('hidden', filter === 'console');
        }
    </script>
</body>
</html>